# GarMCP - Production baseline (Vercel + Claude OAuth)
# Minimal required values are listed first.

# --- Required: MCP OAuth server ---
MCP_OAUTH_ENABLED=true
MCP_OAUTH_CLIENT_ID=garmin-mcp-claude
MCP_OAUTH_CLIENT_SECRET=change-me-oauth-client-secret
MCP_OAUTH_SIGNING_SECRET=change-me-long-random-signing-secret

# --- Required: Persistent Garmin token storage (Upstash via Vercel KV vars) ---
# Keep this as 'vercel-kv' when using KV_REST_API_URL / KV_REST_API_TOKEN.
GARMIN_TOKEN_STORE=vercel-kv
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Required: CORS for browser-based connector flows ---
MCP_ALLOWED_ORIGINS=https://claude.ai

# --- Recommended safe defaults ---
MCP_ENABLE_WRITE_TOOLS=false
GARMIN_MAX_CONCURRENT_REQUESTS=1
MCP_OAUTH_DEFAULT_SCOPES=mcp:read
MCP_OAUTH_REDIRECT_URIS=
MCP_OAUTH_AUTO_REDIRECT=true
MCP_OAUTH_REDIRECT_DELAY_MS=700

# --- Optional compatibility / troubleshooting ---
# Used as namespace base for per-user Garmin token storage.
GARMIN_TOKEN_DIR=/tmp/garmin-mcp

# Optional fallback if token store is unavailable in stateless runtimes.
# GARMIN_EMAIL=you@example.com
# GARMIN_PASSWORD=your-password

# Optional non-OAuth testing path (e.g. MCP Inspector).
# MCP_API_KEY=change-me-to-a-long-random-secret
# MCP_OAUTH_ALLOW_API_KEY_FALLBACK=true

# Optional custom local runtime settings (not needed on Vercel).
# MCP_PORT=8080
# MCP_PATH=/mcp

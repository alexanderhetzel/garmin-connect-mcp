# ------------------------------------------------------------
# Garmin MCP (OAuth with Garmin login on /authorize)
# ------------------------------------------------------------

# Required OAuth server config
MCP_OAUTH_ENABLED=true
MCP_OAUTH_CLIENT_ID=garmin-mcp-claude
MCP_OAUTH_CLIENT_SECRET=change-me-oauth-client-secret
MCP_OAUTH_SIGNING_SECRET=change-me-oauth-signing-secret
MCP_OAUTH_REDIRECT_URIS=

# Required runtime config
GARMIN_TOKEN_DIR=/tmp/garmin-mcp
MCP_ALLOWED_ORIGINS=https://claude.ai

# Network / endpoint config
MCP_PORT=8080
MCP_PATH=/mcp

# Recommended safety / behavior
MCP_ENABLE_WRITE_TOOLS=false
GARMIN_MAX_CONCURRENT_REQUESTS=4
MCP_OAUTH_DEFAULT_SCOPES=mcp:read
MCP_OAUTH_AUTO_REDIRECT=true
MCP_OAUTH_REDIRECT_DELAY_MS=700

# Optional: API key fallback (useful for MCP Inspector/testing)
MCP_API_KEY=change-me-to-a-long-random-secret
MCP_OAUTH_ALLOW_API_KEY_FALLBACK=true

# Legacy/optional fallback account for non-OAuth or API-key-only mode
# GARMIN_EMAIL=you@example.com
# GARMIN_PASSWORD=your-password

# Legacy single-owner OAuth login (not used in Garmin-only login flow)
# MCP_OAUTH_OWNER_USERNAME=
# MCP_OAUTH_OWNER_PASSWORD=
